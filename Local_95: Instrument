rule "Primo VE Marc - Lsr95"
	when
		MARC is "382"."a" AND
		MARC."382"."2" equals "emnmus" OR
		MARC."382"."2" equals "musvok-ie"
	then
		create pnx."search"."lsr95" with MARC "382"."a"
end

rule "Primo VE Marc - Lsr95 - 1"
	when
		MARC is "382"."b" AND
		MARC."382"."2" equals "emnmus"
	then
		create pnx."search"."lsr95" with MARC "382"."b"
end
