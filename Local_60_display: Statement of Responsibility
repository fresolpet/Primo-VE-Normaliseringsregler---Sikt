rule "Primo VE - Lds60"
	when
		MARC is "245"."c"
	then
		set TEMP"1" to MARC."245" sub without sort "c"
		remove substring using regex (TEMP"1","=.*$")
		create pnx."display"."lds60" with TEMP"1"
end

rule "Primo VE - Lds60 - 1"
	when
		MARC is "880" AND
		MARC."880"."6" match "245-.*"
	then
		set TEMP"1" to MARC."880" sub without sort "c"
		remove substring using regex (TEMP"1","(/|:|;|=|,)+$")
		add suffix (TEMP"1"," ")
		create pnx."display"."lds60" with TEMP"1"
end
